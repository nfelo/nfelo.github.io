  "recommended_model_formula": {
    "state": "r ~ Normal(mu, Sigma), with a full team-by-team covariance matrix",
    "era_interpolation": "Linear between 1900, 1930, 1960, 1990, 2020; calibration scale is interpolated in log space; home advantage linearly; draw rate in transformed-logit space.",
    "effective_gap": "delta = a(year)*(mu_i-mu_j) + H(year)*home_sign",
    "base_expected_score": "E = 1/(1+10^(-delta/400))",
    "base_three_way": "D = draw_even(year)*4*E*(1-E); W=E-D/2; L=1-E-D/2",
    "uncertainty_integration": "Integrate (W,D,L) over Normal(delta, a(year)^2*(Sigma_ii+Sigma_jj-2*Sigma_ij)) using 11-point Gauss-Hermite quadrature.",
    "forecast_temperature": "P_final(o) = P_base(o)^T_c / sum_h P_base(h)^T_c; c=friendly when level=0, otherwise competitive.",
    "drift": "Before a participant's match, Sigma_tt += drift_sd^2 * elapsed_years.",
    "match_information": "lambda = quality_scale * G_environment_adjusted(margin); competition-level ratio is 1 for all five levels.",
    "update": "Let v=Sigma[:,i]-Sigma[:,j], V=Sigma_ii+Sigma_jj-2*Sigma_ij, beta=ln(10)*a(year)/400, g=S-E, I=E*(1-E), d=1+lambda*beta^2*I*V. Then mu += v*lambda*beta*g/d and Sigma -= outer(v,v)*lambda*beta^2*I/d.",
    "debut_mean": "median(active mature pool, fallback established pool) + newcomer_offset + active_pool_slope*ln((active_count+10)/50); zero if the reference pool is empty",
    "debut_variance": "prior_sd^2",
    "display_anchor": "Add 1500 to every latent mean if a conventional Elo-looking display scale is desired; the additive anchor does not affect predictions."
  },
